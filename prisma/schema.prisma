generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Whitelist {
  id        Int      @id @default(autoincrement())
  twitter   String
  wallet    String   @unique
  referral  String?
  status    String   @default("Whitelisted")
  createdAt DateTime @default(now())
}
